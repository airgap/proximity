# Proximity — single env surface. Copy to .env and adjust per environment.
# The SAME variables drive local / on-prem / AWS / CF+DO; only values change.

# ---- World server ----
HOST=0.0.0.0
PORT=8080
PUBLIC_WEB_ORIGIN=http://localhost:5173

# ---- Bolt-on authorization (how join grants are verified) ----
# open | shared_secret | oidc | trusted_proxy
PROXIMITY_AUTH_MODE=open
# shared_secret (host, e.g. lyku, mints grant JWTs with this):
PROXIMITY_GRANT_SECRET=
# oidc (company IdP):
# OIDC_ISSUER=https://idp.example.com
# OIDC_JWKS_URI=https://idp.example.com/.well-known/jwks.json
# OIDC_AUDIENCE=proximity
# OIDC_SPACES_CLAIM=groups
# trusted_proxy (auth portal / VPN sets these headers):
# TRUSTED_PROXY_USER_HEADER=x-forwarded-user

# ---- LiveKit (media SFU) ----
# Dev key/secret pair. In prod generate strong values and keep them secret.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret_devsecret_change_me_1234567890
# URL the BROWSER uses to reach LiveKit signaling (must be directly reachable).
LIVEKIT_URL=ws://localhost:7880
# Single UDP mux port for media (easiest firewall ask).
LIVEKIT_UDP_PORT=7882
# Custom egress template that bakes annotations into recordings (the `recorder` service).
# Leave empty to record with LiveKit's built-in grid layout (no annotations).
EGRESS_TEMPLATE_URL=http://recorder
# World-server WS reachable from the egress container's headless browser (baked into recorder).
VITE_WORLD_WS=ws://host.docker.internal:8080/ws

# ---- Postgres ----
# Host port 5442 (dev box already uses 5432); container-internal port stays 5432.
PG_HOST=localhost
PG_PORT=5442
PG_DB=proximity
PG_USER=proximity
PG_PASSWORD=proximity_dev

# ---- Redis ----
# Host port 6399 (dev box already uses 6379).
REDIS_URL=redis://localhost:6399

# ---- S3-compatible object storage (recordings/assets) ----
# Empty endpoint => AWS S3. Set endpoint + force-path-style for MinIO / DO Spaces.
# Host port 9100 (dev box already uses 9000).
S3_ENDPOINT=http://localhost:9100
S3_REGION=us-east-1
S3_BUCKET=proximity-recordings
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
# The egress container uploads recordings; it reaches MinIO via the docker host gateway,
# not the app's localhost. (minio:9000 also works if the app runs inside compose.)
EGRESS_S3_ENDPOINT=http://host.docker.internal:9100

# ---- Recording post-processing worker ----
# Whisper ggml model for transcription (mount + set). Without it, recordings aren't transcribed.
# WHISPER_MODEL=/models/ggml-tiny.en.bin
# LLM gguf model for the notetaker summary/action-items (else a deterministic extractive fallback).
# LLM_MODEL=/models/llama-3.2-1b-instruct-q4.gguf
# Where the notetaker POSTs the generated meeting note (host implements the receiver, e.g. a
# lyku channel bot). Omit to just store the note artifact in object storage.
# NOTETAKER_WEBHOOK_URL=https://api.lyku.co/api/proximity/notes
