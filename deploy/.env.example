# Proximity — single env surface. Copy to .env and adjust per environment.
# The SAME variables drive local / on-prem / AWS / CF+DO; only values change.

# ---- World server ----
HOST=0.0.0.0
PORT=8080
PUBLIC_WEB_ORIGIN=http://localhost:5173

# ---- LiveKit (media SFU) ----
# Dev key/secret pair. In prod generate strong values and keep them secret.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret_devsecret_change_me_1234567890
# URL the BROWSER uses to reach LiveKit signaling (must be directly reachable).
LIVEKIT_URL=ws://localhost:7880
# Single UDP mux port for media (easiest firewall ask).
LIVEKIT_UDP_PORT=7882

# ---- Postgres ----
# Host port 5442 (dev box already uses 5432); container-internal port stays 5432.
PG_HOST=localhost
PG_PORT=5442
PG_DB=proximity
PG_USER=proximity
PG_PASSWORD=proximity_dev

# ---- Redis ----
# Host port 6399 (dev box already uses 6379).
REDIS_URL=redis://localhost:6399

# ---- S3-compatible object storage (recordings/assets) ----
# Empty endpoint => AWS S3. Set endpoint + force-path-style for MinIO / DO Spaces.
# Host port 9100 (dev box already uses 9000).
S3_ENDPOINT=http://localhost:9100
S3_REGION=us-east-1
S3_BUCKET=proximity-recordings
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
